# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Pooled URL — used at runtime by Prisma Client
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
# Non-pooled URL — used by Prisma Migrate / db push
DIRECT_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ─── Auth.js v5 ───────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
# Production URL (no trailing slash)
NEXTAUTH_URL=https://your-app.vercel.app

# ─── AI ───────────────────────────────────────────────────────────────────────
# "xai" (default) or "openai"
AI_PROVIDER=xai
XAI_API_KEY=xai-...
OPENAI_API_KEY=sk-...

# AI Brain bearer token (optional — leave empty to allow unauthenticated)
AI_BRAIN_TOKEN=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# The Stripe Price ID for hour-pack purchases
STRIPE_HPP_PRICE_ID=price_...

# ─── Basecamp ────────────────────────────────────────────────────────────────
BASECAMP_ACCOUNT_ID=
BASECAMP_CLIENT_ID=
BASECAMP_CLIENT_SECRET=
BASECAMP_REDIRECT_URI=https://your-app.vercel.app/api/basecamp/callback

# ─── Slack ────────────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
SLACK_JOB_BOARD_CHANNEL_ID=
SLACK_OPS_CHANNEL_ID=
SLACK_FOUNDERS_CHANNEL_ID=

# ─── Clockify ────────────────────────────────────────────────────────────────
CLOCKIFY_API_KEY=
CLOCKIFY_WORKSPACE_ID=

# ─── Inngest ──────────────────────────────────────────────────────────────────
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ─── Cron security ────────────────────────────────────────────────────────────
# Must match the Authorization header Vercel sends for cron jobs
CRON_SECRET=changeme-random-secret

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
BIZTIME_TZ=America/New_York

# ─── Feature flags ────────────────────────────────────────────────────────────
MSP_ENFORCEMENT=true
ACS_ENABLED=true
DIM_ENABLED=true
INTAKE_GATE_ENABLED=true
INTAKE_CLARIFY_ENABLED=true
JOB_BOARD_AI_RECOMMEND_ENABLED=true
SLACK_OUTBOUND_ENABLED=true