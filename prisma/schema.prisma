  assigned_va_id                           String?
  assigned_va_name                         String?
  last_customer_at                         DateTime?
  last_customer_author                     String?
  last_customer_text                       String?
  last_tb_reply_at                         DateTime?
  last_tb_reply_text                       String?
  last_internal_comment_creator_id         String?
  last_internal_comment_has_attachments    Boolean?
