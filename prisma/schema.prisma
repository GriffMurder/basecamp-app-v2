  @@map("ops_weekly_briefs")
}

model VaWeeklyScorecard {
  id                  Int       @id @default(autoincrement())
  slack_user_id       String
  week_start          DateTime
  generated_at        DateTime  @default(now())
  source_data_json    Json      @default("{}")
  scorecard_json      Json      @default("{}")
