  @@map("job_board_posts")
}

model JobBoardSkip {
  id             Int      @id @default(autoincrement())
  todo_id        String
  skipped_reason String
  skipped_at     DateTime @default(now())
  run_id         String?
  project_id     String?
  todolist_id    String?
  title          String?
  @@index([todo_id])
  @@map("job_board_skips")
}

model JobBoardCandidate {
  id                          Int       @id @default(autoincrement())
  todo_id                     String
  slack_user_id               String
  basecamp_person_id          String?
  created_at                  DateTime  @default(now())
  status                      String    @default("active")
  selected_at                 DateTime?
  selected_by_slack_user_id   String?
  source                      String    @default("slack_interested")
  note                        String?
  features_json               Json      @default("{}")
  score_overall               Decimal?  @db.Decimal(5, 2)
  score_breakdown_json        Json      @default("{}")
  @@map("job_board_candidates")
}

model JobBoardRecommendation {
  id                        Int       @id @default(autoincrement())
  todo_id                   String
  created_at                DateTime  @default(now())
  created_by                String?
  model                     String?
  prompt_version            String?
  ranking_json              Json      @default("{}")
  selected_slack_user_id    String?
  rationale                 String?
  @@map("job_board_recommendations")
}

