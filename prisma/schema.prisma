model SystemPostHistory {
  id                    Int      @id @default(autoincrement())
  basecamp_todo_id      String
  purpose               String
  fingerprint           String
  basecamp_comment_id   String?
  actor                 String?
  source_path           String?
  created_at            DateTime @default(now())
  @@index([basecamp_todo_id])
  @@index([purpose])
  @@index([created_at])
  @@map("system_post_history")
}

model BasecampPersonToken {
  person_id     String    @id
  token         String
  refresh_token String?
  expires_at    DateTime?
  slack_user_id String?
  created_at    DateTime  @default(now())
  updated_at    DateTime  @default(now()) @updatedAt
  @@map("basecamp_person_tokens")
}

// ── AI Layer ─────────────────────────────────────────────────────────────────

model AiTask {
  id                    BigInt   @id @default(autoincrement())
  org_id                Int?
  basecamp_todo_id      String
  basecamp_project_id   String?
  basecamp_bucket_id    String?
  thread_url            String?
  title                 String?
  status                String   @default("open")
  created_at            DateTime @default(now())
  updated_at            DateTime @default(now()) @updatedAt
  @@index([basecamp_todo_id])
  @@map("ai_tasks")
}

model AiTaskEvent {
  id           BigInt   @id @default(autoincrement())
  org_id       Int?
  task_id      BigInt
  event_ts     DateTime @default(now())
  event_type   String
  actor_id     String?
  channel      String   @default("system")
  external_id  String?
  payload_json Json     @default("{}")
  dedupe_key   String?  @unique
  @@index([task_id])
  @@map("ai_task_events")
}

model AiReport {
  id                       BigInt    @id @default(autoincrement())
  org_id                   Int?
  report_type              String
  period_start             DateTime?
  period_end               DateTime?
  generated_at             DateTime  @default(now())
  summary_text             String
  highlights_json          Json      @default("{}")
  recommendations_json     Json      @default("{}")
  slack_channel            String?
  posted_to_slack_ts       String?
  @@map("ai_reports")
}

model Interaction {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source           String
  customer_id      Int
  todo_id          String?
  person_id        Int?
  interaction_type String
  happened_at      DateTime
  payload          Json?
  @@index([customer_id])
  @@index([todo_id])
  @@index([person_id])
  @@index([interaction_type])
  @@index([happened_at])
  @@map("interactions")
}

model Intervention {
  id                              BigInt    @id @default(autoincrement())
  level                           String
  reason                          String
  target_person_id                String?
  customer_id                     Int?
  todo_id                         String?
  status                          String    @default("open")
  created_at                      DateTime  @default(now())
  sent_at                         DateTime?
  response_at                     DateTime?
  resolved_at                     DateTime?
  resolution_kind                 String?
  root_cause_category             String?
  resolution_note                 String?
  slack_msg_ts                    String?
  slack_channel_id                String?
  bc_verify_started_at            DateTime?
  bc_verify_comment_found         Boolean?
  bc_verify_comment_id            String?
  bc_verify_checked_at            DateTime?
  basecamp_verified_at            DateTime?
  basecamp_verification_failed    Boolean?
  parent_intervention_id          BigInt?
  sla_due_at                      DateTime?
  sla_breached_at                 DateTime?
  resolution_action               String?
  @@index([target_person_id])
  @@index([todo_id])
  @@index([slack_msg_ts])
  @@map("interventions")
}

// ── Scoring ──────────────────────────────────────────────────────────────────

model ScoreDaily {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  day         DateTime
  customer_id Int?
  person_id   Int?
  score_type  String
  score_value Decimal   @db.Decimal(5, 2)
  trend_value Decimal?  @db.Decimal(6, 2)
  band        String?
  flags       Json?
  @@unique([day, score_type, customer_id, person_id], name: "scores_daily_unique_day_type_subject")
  @@index([day])
  @@index([customer_id])
  @@index([person_id])
  @@map("scores_daily")
}

model Tier {
  id                    Int       @id @default(autoincrement())
  customer_id           Int       @unique
  auto_tier             String    @default("B")
  auto_tier_computed_at DateTime?
  manual_tier           String?
  manual_tier_set_by    String?
  manual_tier_set_at    DateTime?
  effective_tier        String    @default("B")
  computed_at           DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt
  @@index([effective_tier])
  @@map("tiers")
}

model ManagerReview {
  id                Int       @id @default(autoincrement())
  manager_id        Int
  triggered_at      DateTime  @default(now())
  trigger_reason    String?
  scheduled_for_at  DateTime?
  notes             String?
  closed_at         DateTime?
  created_at        DateTime  @default(now())
  @@index([manager_id])
  @@map("manager_reviews")
}

model VaMetricsDaily {
  org_id              Int      @default(0)
  person_id           String
  day                 DateTime
  tasks_touched       Int      @default(0)
  tasks_completed     Int      @default(0)
  sla_breaches        Int      @default(0)
  ops_escalations     Int      @default(0)
  pending_followups   Int      @default(0)
  quality_score       Decimal? @db.Decimal(5, 2)
  @@id([org_id, person_id, day])
  @@map("va_metrics_daily")
}

model VaPerformanceSnapshot {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  va_id        String    @db.Uuid
  period_start DateTime
  period_end   DateTime
  metrics_json Json      @default("{}")
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now()) @updatedAt
  @@unique([va_id, period_start, period_end], name: "va_perf_snap_unique")
  @@index([va_id])
  @@index([period_start])
  @@index([period_end])
  @@map("va_performance_snapshots")
}

model VaLoadState {
  va_id             String   @id @db.Uuid
  active_task_count Int      @default(0)
  throttle_level    String   @default("normal")
  burnout_flag      Boolean  @default(false)
  reasons_json      Json     @default("[]")
  updated_at        DateTime @default(now()) @updatedAt
  @@map("va_load_state")
}

// ── Job Board ────────────────────────────────────────────────────────────────

model JobBoardPost {
  id                          Int       @id @default(autoincrement())
  todo_id                     String    @unique
  bucket_id                   String?
  project_id                  String?
  todo_title                  String    @default("")
  todo_url                    String?
  status                      String    @default("posted")
  first_seen_at               DateTime  @default(now())
  posted_at                   DateTime  @default(now())
  last_seen_unassigned_at     DateTime?
  first_posted_at             DateTime?
  posted_by_run_id            String?
  claimed_at                  DateTime?
  claimed_by_slack_user_id    String?
  assigned_at                 DateTime?
  assigned_by_slack_user_id   String?
  assigned_basecamp_person_id String?
  selected_slack_user_id      String?
  closed_at                   DateTime?
  expired_at                  DateTime?
  rescinded_at                DateTime?
  slack_channel_id            String    @default("")
  slack_ts                    String?
  slack_permalink             String?
  last_post_error             String?
  last_post_attempt_at        DateTime?
  post_attempts               Int       @default(0)
  last_escalated_at           DateTime?
