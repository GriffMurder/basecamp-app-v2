// Basecamp App -- Prisma Schema
// Migrated from Python/SQLAlchemy app/models.py (60 models)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ── Auth.js v5 ───────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  @@map("auth_users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

// ── Multi-tenant ─────────────────────────────────────────────────────────────

model Organization {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  name       String
  is_active  Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @default(now()) @updatedAt
  @@map("organizations")
}

model OrganizationSettings {
  org_id        Int      @id
  settings_json Json     @default("{}")
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt
  @@map("organization_settings")
}

model DashboardUser {
  id                  Int       @id @default(autoincrement())
  auth_user_id        String?   @unique
  email               String    @unique
  display_name        String    @default("")
  name                String?
  password_hash       String?
  role                String    @default("pending")
  availability_status String    @default("available")
  away_note           String?
  manager_id          Int?
  approved_by         Int?
  approved_at         DateTime?
  last_login_at       DateTime?
  active              Boolean   @default(true)
  org_id              Int?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt
  @@map("dashboard_users")
}

// ── People / Roles ───────────────────────────────────────────────────────────

model Person {
  id                  Int       @id @default(autoincrement())
  slack_user_id       String?   @unique
  basecamp_person_id  String?   @unique
  display_name        String    @default("")
  email               String?   @unique
  role                String
  active              Boolean   @default(true)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt
  @@map("people")
}

model Customer {
  id                      Int       @id @default(autoincrement())
  name                    String
  basecamp_project_id     String?   @unique
  clockify_client_id      String?   @unique
  slack_channel_id        String?
  external_id             String?   @unique
  active                  Boolean   @default(true)
  client_health_score     Int?
  client_difficulty_index Int?
  last_scored_at          DateTime?
  auto_tier               String?
  manual_tier             String?
  effective_tier          String?
  tier_computed_at        DateTime?
  bucket_balance          Decimal?  @db.Decimal(10, 2)
  bucket_last_added_at    DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @default(now()) @updatedAt
  carReports              CarReport[]
  @@map("customers")
}

model Va {
  id                  Int       @id @default(autoincrement())
  slack_user_id       String?   @unique
  basecamp_person_id  String?   @unique
  clockify_user_id    String?   @unique
  display_name        String    @default("")
  email               String?   @unique
  active              Boolean   @default(true)
  reliability_score   Int?
  capacity_index      Int?
  last_scored_at      DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt
  @@map("vas")
}

model Manager {
  id                          Int       @id @default(autoincrement())
  slack_user_id               String    @unique
  basecamp_person_id          String?   @unique
  display_name                String    @default("")
  email                       String?   @unique
  active                      Boolean   @default(true)
  default_manual_tier         String?
  default_manual_tier_set_by  String?
  default_manual_tier_set_at  DateTime?
  accountability_score        Int?
  last_scored_at              DateTime?
  created_at                  DateTime  @default(now())
  updated_at                  DateTime  @default(now()) @updatedAt
  @@map("managers")
}

model AccountManager {
  id            Int      @id @default(autoincrement())
  slack_user_id String   @unique
  created_at    DateTime @default(now())
  created_by    String?
  @@map("account_managers")
}

model PeopleMap {
  id                      Int      @id @default(autoincrement())
  basecamp_person_id      String?  @unique
  basecamp_person_name    String?
  basecamp_person_type    String?
  slack_user_id           String
  role                    String
  is_client               Boolean?
  is_internal             Boolean  @default(false)
  @@map("people_map")
}

// ── Assignments ──────────────────────────────────────────────────────────────

model CustomerAssignment {
  id                          Int       @id @default(autoincrement())
  customer_id                 Int
  manager_id                  Int
  is_primary                  Boolean   @default(true)
  active                      Boolean   @default(true)
  assigned_at                 DateTime  @default(now())
  unassigned_at               DateTime?
  assigned_by_slack_user_id   String?
  @@unique([customer_id, manager_id], name: "customer_assignments_unique")
  @@index([customer_id])
  @@index([manager_id])
  @@map("customer_assignments")
}

model TaskOwnership {
  id                  Int       @id @default(autoincrement())
  todo_id             String
  bucket_id           String
  customer_id         Int
  responsible_va_id   Int
  contributor_va_ids  Json?
  active              Boolean   @default(true)
  assigned_at         DateTime  @default(now())
  unassigned_at       DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt
  @@unique([todo_id, bucket_id], name: "task_ownership_todo_bucket_unique")
  @@index([customer_id])
  @@index([responsible_va_id])
  @@map("task_ownership")
}

model AssignmentSlackOverride {
  id                          Int      @id @default(autoincrement())
  basecamp_todo_id            String
  basecamp_person_id          String
  slack_user_id               String
  created_by_slack_user_id    String?
  created_at                  DateTime @default(now())
  expires_at                  DateTime
  @@unique([basecamp_todo_id, basecamp_person_id], name: "assignment_slack_overrides_unique")
  @@index([basecamp_todo_id])
  @@index([basecamp_person_id])
  @@map("assignment_slack_overrides")
}

model AssignmentOverride {
  id                               BigInt   @id @default(autoincrement())
  todo_id                          String
  bucket_id                        String?
  recommended_va_slack_user_id     String?
  override_va_slack_user_id        String
  overriding_manager_slack_user_id String?
  override_reason                  String?
  risk_level                       String
  warn_flags                       Json     @default("{}")
  created_at                       DateTime @default(now())
  @@index([todo_id])
  @@map("assignment_overrides")
}

// ── Legacy (Project / Message / Task / TaskClaim) ────────────────────────────

model Project {
  id                          Int       @id @default(autoincrement())
  basecamp_project_id         String?   @unique
  account_manager_slack_id    String?
  active                      Boolean   @default(true)
  last_seen_activity_at       DateTime?
  @@map("projects")
}

model Message {
  id                    Int       @id @default(autoincrement())
  basecamp_message_id   String?   @unique
  project_id            Int?
  author_role           String?
  raw_text              String?
  stripped_text         String?
  classification        String?
  summary               String?
  skills                Json?
  created_at            DateTime  @default(now())
  @@index([project_id])
  @@map("messages")
}

model Task {
  id                     Int       @id @default(autoincrement())
  source                 String?
  source_id              Int?
  project_id             Int?
  slack_message_ts       String?
  assignee_slack_id      String?
  status                 String    @default("OPEN")
  created_at             DateTime  @default(now())
  due_at                 DateTime?
  assigned_at            DateTime?
  check_ins_required     Boolean   @default(false)
  last_check_in_at       DateTime?
  next_check_in_at       DateTime?
  check_ins_remaining    Int       @default(0)
  @@index([project_id])
  @@index([slack_message_ts])
  @@map("tasks")
}

model TaskClaim {
  id                  Int       @id @default(autoincrement())
  task_id             Int
  slack_user_id       String
  slack_user_name     String?
  skills              Json?
  can_meet_due_date   Boolean?
  order               Int
  created_at          DateTime  @default(now())
  @@index([task_id])
  @@index([slack_user_id])
  @@map("task_claims")
}

// ── Basecamp Sync ────────────────────────────────────────────────────────────

model BcBucket {
  bucket_id   String   @id
  customer_id Int?
  name        String?
  created_at  DateTime @default(now())
  updated_at  DateTime @default(now()) @updatedAt
  @@index([customer_id])
  @@map("bc_buckets")
}

model BcTodo {
  todo_id               String    @id
  bucket_id             String?
  customer_id           Int?
  responsible_person_id Int?
  last_activity_at      DateTime?
  due_at                DateTime?
  completed_at          DateTime?
  url                   String?
  status                String    @default("open")
  created_at            DateTime  @default(now())
  updated_at            DateTime  @default(now()) @updatedAt
  @@index([bucket_id])
  @@index([customer_id])
  @@index([responsible_person_id])
  @@map("bc_todos")
}

model BcEvent {
  id          BigInt   @id @default(autoincrement())
  todo_id     String?
  bucket_id   String?
  event_type  String
  actor_id    String?
  payload     Json     @default("{}")
  happened_at DateTime
  ingested_at DateTime @default(now())
  external_id String?  @unique
  @@index([todo_id])
  @@index([bucket_id])
  @@index([event_type])
  @@index([happened_at])
  @@map("bc_events")
}

model BasecampTodo {
  id                              Int       @id @default(autoincrement())
  basecamp_todo_id                String    @unique
  basecamp_project_id             String
  basecamp_todolist_id            String
  project_name                    String?
  todolist_name                   String?
  title                           String?
  description                     String?
  urls                            Json?
  due_on                          DateTime?
  due_in_days                     Int?
  assignee_id                     String?
  assignee_name                   String?
  assigned_at                     DateTime?
  updated_at                      DateTime?
  completed                       Boolean   @default(false)
  completed_at                    DateTime?
  workflow_state                  String?
  commitment_recorded             Boolean   @default(false)
  commitment_note                 String?
  followup_half_at                DateTime?
  followup_final_third_at         DateTime?
  risk_overdue                    Boolean   @default(false)
  risk_due_soon                   Boolean   @default(false)
  risk_unassigned_due_soon        Boolean   @default(false)
  risk_assigned_uncommitted       Boolean   @default(false)
  risk_no_due_date                Boolean   @default(false)
  created_at                      DateTime  @default(now())
  seen_at                         DateTime  @default(now())
  last_synced_at                  DateTime  @default(now())
  last_seen_unassigned_at         DateTime?
  ai_clarify_posted_at            DateTime?
  ai_clarify_comment_id           String?
  intake_state                    String?
  intake_last_ping_at             DateTime?
  intake_ping_count               Int?
  intake_comment_id               String?
  intake_last_customer_comment_id String?
  ai_meeting_is_meeting           Boolean?
  ai_meeting_confidence           Decimal?  @db.Decimal(5, 2)
  ai_meeting_reason               String?
  ai_meeting_classified_at        DateTime?
  lifecycle_state                 String    @default("CREATED")
  lifecycle_updated_at            DateTime?
  completion_signal_detected_at   DateTime?
  on_hold_until                   DateTime?
  @@index([basecamp_project_id])
  @@index([basecamp_todolist_id])
  @@map("basecamp_todos")
}

