// ── Task Intelligence (ACS/MSP) ──────────────────────────────────────────────

model TaskSuccessPlan {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  basecamp_thread_id   String    @unique
  client_id            String?   @db.Uuid
  va_id                String?   @db.Uuid
  generated_plan       Json
  va_modified_plan     Json?
  task_type_suggested  String
  task_type_final      String?
  status               String    @default("generated")
  confirmed_at         DateTime?
  created_at           DateTime  @default(now())
  updated_at           DateTime  @default(now()) @updatedAt
  @@index([basecamp_thread_id])
  @@index([client_id])
  @@index([va_id])
  @@map("task_success_plans")
}

model TaskCompletionReport {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  basecamp_thread_id  String    @unique
  client_id           String?   @db.Uuid
  va_id               String?   @db.Uuid
  success_plan_id     String?   @db.Uuid
  task_type           String    @default("other")
  draft_report        Json
  approved_report     Json?
  status              String    @default("drafted")
  approved_at         DateTime?
  posted_at           DateTime?
  basecamp_post_id    String?
  error               String?
  completed_at        DateTime?
  edit_count          Int       @default(0)
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt
  @@index([basecamp_thread_id])
  @@index([client_id])
  @@index([va_id])
  @@map("task_completion_reports")
}

model TaskQualityEvent {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  basecamp_thread_id    String
  basecamp_comment_id   String
  comment_author        String?
  event_type            String
  matched_keywords      Json      @default("[]")
  snippet               String
  dedupe_key            String    @unique
  created_at            DateTime  @default(now())
  processed_at          DateTime  @default(now())
  @@index([basecamp_thread_id])
  @@index([basecamp_comment_id])
  @@index([event_type])
  @@map("task_quality_events")
}

model ClientPlaybook {
  client_id       String    @id @db.Uuid
  playbook_json   Json      @default("{}")
  top_rules       Json      @default("[]")
  signals_json    Json      @default("{}")
  last_built_at   DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @default(now()) @updatedAt
  @@map("client_playbooks")
}

model TaskIntegrityFinding {
  id           Int       @id @default(autoincrement())
  todo_id      Int
  finding_type String
  detail       String?
  severity     String    @default("warning")
  detected_at  DateTime  @default(now())
  resolved_at  DateTime?
  @@unique([finding_type, todo_id], name: "uq_finding_todo")
  @@map("task_integrity_findings")
}

// ── Billing / Buckets ─────────────────────────────────────────────────────────

model Bucket {
  id                     Int       @id @default(autoincrement())
  customer_id            Int
  hours_purchased        Decimal   @default(0) @db.Decimal(10, 2)
  hours_used             Decimal   @default(0) @db.Decimal(10, 2)
  hours_balance          Decimal   @default(0) @db.Decimal(10, 2)
  status                 String    @default("active")
  stripe_payment_id      String?
  stripe_subscription_id String?
  purchased_at           DateTime  @default(now())
  rollover_date          DateTime?
  notes                  String?
  hpp_protected          Boolean   @default(false)
  hpp_paused_at          DateTime?
  hpp_resumed_at         DateTime?
  is_bonus               Boolean   @default(false)
  bonus_expires_at       DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @default(now()) @updatedAt
  @@index([customer_id])
  @@index([stripe_payment_id])
  @@index([stripe_subscription_id])
  @@map("buckets")
}

model TimeEntry {
  id                  Int       @id @default(autoincrement())
  bucket_id           Int?
  customer_id         Int
  va_id               Int?
  basecamp_todo_id    String?
  clockify_entry_id   String?   @unique
  start_time          DateTime?
  end_time            DateTime?
  duration_minutes    Decimal   @db.Decimal(8, 2)
  description         String?
  status              String    @default("draft")
  approved_at         DateTime?
  approved_by         Int?
  rejected_reason     String?
  notes               String?
  attachments         Json      @default("[]")
  edit_history        Json      @default("[]")
  device_info         Json?
  ip_address          String?
  user_agent          String?
  geo_location        Json?
  dashboard_user_id   Int?
  payroll_locked      Boolean   @default(false)
  payroll_lock_date   DateTime?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @default(now()) @updatedAt
  @@index([bucket_id])
  @@index([customer_id])
  @@index([va_id])
  @@index([basecamp_todo_id])
  @@map("time_entries")
}

model HppSubscription {
  id                      Int       @id @default(autoincrement())
  customer_id             Int
  stripe_subscription_id  String    @unique
  status                  String    @default("active")
  current_period_start    DateTime?
  current_period_end      DateTime?
  cancelled_at            DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @default(now()) @updatedAt
  @@index([customer_id])
  @@map("hpp_subscriptions")
}

model PayrollConfig {
  id             Int      @id @default(autoincrement())
  lock_day_1     Int      @default(1)
  lock_day_2     Int      @default(15)
  reminder_hours Int      @default(48)
  updated_by     Int?
  updated_at     DateTime @default(now()) @updatedAt
  @@map("payroll_config")
}

model StripeEvent {
  id               Int      @id @default(autoincrement())
  stripe_event_id  String   @unique
  event_type       String
  processed        Boolean  @default(false)
  payload_summary  Json?
  customer_id      Int?
  bucket_id        Int?
  error            String?
  created_at       DateTime @default(now())
  @@map("stripe_events")
}

// ── Clockify Integration ──────────────────────────────────────────────────────

model ClockifyProject {
  id                  Int       @id @default(autoincrement())
  clockify_project_id String    @unique
  customer_id         Int?
  name                String    @default("")
  archived            Boolean   @default(false)
  color               String?
  billable            Boolean   @default(true)
  hourly_rate         Decimal?  @db.Decimal(10, 2)
  clockify_client_id  String?
  synced_at           DateTime  @default(now())
  created_at          DateTime  @default(now())
  @@index([customer_id])
  @@map("clockify_projects")
}

model ClockifyTag {
  id              Int      @id @default(autoincrement())
  clockify_tag_id String   @unique
  name            String   @default("")
  archived        Boolean  @default(false)
  synced_at       DateTime @default(now())
  created_at      DateTime @default(now())
  @@map("clockify_tags")
}

model ClockifyTask {
  id                  Int      @id @default(autoincrement())
  clockify_task_id    String   @unique
  clockify_project_id String?
  name                String   @default("")
  status              String   @default("ACTIVE")
  assignee_ids        Json     @default("[]")
  synced_at           DateTime @default(now())
  created_at          DateTime @default(now())
  @@map("clockify_tasks")
}

model ClockifySyncLog {
  id             Int       @id @default(autoincrement())
  entity_type    String
  last_synced_at DateTime?
  entries_synced Int       @default(0)
  status         String    @default("running")
  error          String?
  created_at     DateTime  @default(now())
  @@map("clockify_sync_log")
}

// ── Payment Events ─────────────────────────────────────────────────────────────

model PaymentEvent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider     String                        // paypal | veem | stripe
  event_type   String
  provider_ref String?   @unique             // idempotency key from provider
  amount_cents Int?
  currency     String?   @default("USD")
  customer_id  Int?
  bucket_id    Int?
  status       String    @default("received")
  raw_payload  Json?
  error        String?
  created_at   DateTime  @default(now())
  @@index([provider])
  @@index([customer_id])
  @@index([created_at])
  @@map("payment_events")
}

// ── Client Advantage Reports ────────────────────────────────────────────────

model CarReport {
  id              Int      @id @default(autoincrement())
  customer_id     Int
  period_start    DateTime @db.Date
  period_end      DateTime @db.Date
  metrics_json    Json
  narrative_json  Json
  generated_at    DateTime @default(now())
  generation_type String   @default("monthly")
  customer        Customer @relation(fields: [customer_id], references: [id])

  @@unique([customer_id, period_start, period_end])
  @@index([customer_id])
  @@index([period_start])
  @@map("car_reports")
}
